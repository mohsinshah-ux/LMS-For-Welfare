generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  active
  inactive
  suspended
}

enum ApplicationStatus {
  draft
  submitted
  verification
  manager_review
  approved
  agreement_generation
  disbursed
  active
  closed
  rejected
}

enum InstallmentStatus {
  pending
  paid
  partial
  overdue
  written_off
}

enum PaymentMethod {
  cash
  bank_transfer
  mobile_wallet
  cheque
}

model User {
  id           String        @id @default(uuid())
  username     String        @unique
  email        String        @unique
  passwordHash String
  status       UserStatus    @default(active)
  branchId     String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  roles        UserRole[]
  customers    Customer[]
  applications FinancingApplication[]
}

model Role {
  id          String           @id @default(uuid())
  code        String           @unique
  name        String
  permissions RolePermission[]
  users       UserRole[]
}

model Permission {
  id    String           @id @default(uuid())
  code  String           @unique
  name  String
  roles RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model UserRole {
  userId String
  roleId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model Customer {
  id           String                  @id @default(uuid())
  customerId   String                  @unique
  fullName     String
  cnic         String                  @unique
  mobileNumber String
  email        String?
  createdById  String?
  createdBy    User?                   @relation(fields: [createdById], references: [id])
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  applications FinancingApplication[]
}

model FinancingApplication {
  id              String            @id @default(uuid())
  applicationNo   String            @unique
  customerId      String
  financingType   String
  financingAmount Decimal           @db.Decimal(16, 2)
  status          ApplicationStatus @default(draft)
  createdById     String?
  createdBy       User?             @relation(fields: [createdById], references: [id])
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  customer        Customer          @relation(fields: [customerId], references: [id])
  installments    Installment[]
}

model Installment {
  id                String             @id @default(uuid())
  applicationId     String
  installmentNumber Int
  dueDate           DateTime
  principalAmount   Decimal            @db.Decimal(16, 2)
  profitAmount      Decimal            @db.Decimal(16, 2)
  totalDue          Decimal            @db.Decimal(16, 2)
  paidAmount        Decimal            @default(0) @db.Decimal(16, 2)
  outstandingAmount Decimal            @db.Decimal(16, 2)
  status            InstallmentStatus  @default(pending)
  application       FinancingApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  payments          Payment[]

  @@unique([applicationId, installmentNumber])
}

model Payment {
  id               String        @id @default(uuid())
  installmentId    String
  paymentDate      DateTime
  paymentMethod    PaymentMethod
  transactionId    String?
  amountPaid       Decimal       @db.Decimal(16, 2)
  profitPortion    Decimal       @default(0) @db.Decimal(16, 2)
  principalPortion Decimal       @default(0) @db.Decimal(16, 2)
  remainingBalance Decimal       @default(0) @db.Decimal(16, 2)
  createdAt        DateTime      @default(now())
  installment      Installment   @relation(fields: [installmentId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  action     String
  entityType String?
  entityId   String?
  oldValues  Json?
  newValues  Json?
  ipAddress  String?
  deviceInfo String?
  createdAt  DateTime @default(now())
}
